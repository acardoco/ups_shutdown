{
  "general": {
    "lock_file": "/var/lock/ups-shutdown.lock"
  },
  "ups": {
    "target": "ups0@122.138.123.34",
    "upsc_binary": "upsc",
    "require_on_battery": true,
    "shutdown_charge_lte": 50,
    "shutdown_runtime_lte": null
  },
  "kubernetes": {
    "kubeconfig": "/etc/rancher/k3s/k3s.yaml",
    "kubectl_cmd": ["kubectl"],
    "app_namespaces": ["media", "immich", "nextcloud"],
    "wait": {
      "timeout_seconds": 600,
      "poll_seconds": 10,
      "ignore_owner_kinds": ["Cluster"],
      "ignore_pod_prefixes": []
    },
    "drain": {
      "timeout": "10m",
      "grace_period": 60,
      "delete_emptydir_data": true,
      "force": true
    }
  },
  "workers": {
    "ssh_options": [
      "-o", "BatchMode=yes",
      "-o", "ConnectTimeout=10"
    ],
    "poweroff_command": ["systemctl", "poweroff"],
    "poweroff": {
      "inter_worker_delay_seconds": 10
    },
    "nodes": [
      {
        "host": "worker1",
        "ssh_user": "user1",
        "ssh_port": 22,
        "use_sudo": true
      },
      {
        "host": "worker2",
        "ssh_user": "user2",
        "ssh_port": 22,
        "use_sudo": true
      }
    ]
  },
  "master": {
    "pre_poweroff_delay_seconds": 60,
    "poweroff_command": ["systemctl", "poweroff"]
  }
}